# =============================================================================
# VARIÁVEIS DE AMBIENTE PARA PRODUÇÃO (RENDER.COM)
# =============================================================================

# ---------------------
# Backend API (Express)
# ---------------------
NODE_ENV=production
PORT=3000

# PostgreSQL (fornecido automaticamente pelo Render)
DATABASE_URL=postgresql://user:password@host:5432/database

# Configurações de E-mail (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-aplicativo-aqui
EMAIL_FROM=JLA Importadora <seu-email@gmail.com>

# ---------------------
# Frontend (Next.js)
# ---------------------
# URL da API backend (configurar após deploy do backend)
# Opções: usar domínio customizado ou URL do Render
NEXT_PUBLIC_API_URL=https://api.jla.avilaops.com
# OU: NEXT_PUBLIC_API_URL=https://jla-importadora-api.onrender.com

# Base URL do site (domínio customizado)
NEXT_PUBLIC_BASE_URL=https://jla.avilaops.com
